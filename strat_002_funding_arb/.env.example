# ═══════════════════════════════════════════════════════════════════════════════
# STRAT-002: Funding Rate Arbitrage — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values. Never commit .env to version control.

# Binance API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Operating mode: "paper" or "live"
BOT_MODE=paper

# Alerting (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Dashboard
DASHBOARD_PORT=8082

# Database
DATABASE_URL=sqlite:///data/bot.db

# Logging
LOG_LEVEL=INFO
