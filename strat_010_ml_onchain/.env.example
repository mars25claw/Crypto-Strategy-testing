# =============================================================================
# STRAT-010: ML & On-Chain Quantitative Models — Environment Variables
# =============================================================================
# Copy to .env and fill in real values. NEVER commit .env to version control.

# Binance API
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Operating mode: "paper" or "live"
BOT_MODE=paper

# Glassnode on-chain data
GLASSNODE_API_KEY=your_glassnode_api_key_here

# LunarCrush social sentiment
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here

# CryptoCompare social data (fallback)
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=
