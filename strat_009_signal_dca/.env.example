# =============================================================================
# STRAT-009 Signal-Enhanced DCA Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Binance API ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# --- Bot Mode ---
# "paper" for paper trading, "live" for real trading
BOT_MODE=paper

# --- Config Path (optional, defaults to config.yaml) ---
# CONFIG_PATH=/app/config.yaml

# --- Glassnode API (optional, for SOPR on-chain data) ---
# GLASSNODE_API_KEY=your_glassnode_key_here

# --- Alerting (optional) ---
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
