# ============================================================================
# STRAT-003: Statistical Arbitrage Pairs Trading Bot — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Binance API Credentials ────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Bot Mode ───────────────────────────────────────────────────────────────
# "paper" for paper trading, "live" for real trading
BOT_MODE=paper

# ── Config Path (optional override) ───────────────────────────────────────
CONFIG_PATH=config.yaml

# ── Alerting (optional) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── Database (optional override) ──────────────────────────────────────────
DATABASE_URL=sqlite:///data/strat003.db
