# STRAT-008: Options & Volatility Strategies — Environment Variables
# Copy this file to .env and fill in your credentials.

# ── Binance ──────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Deribit (optional — enables Full mode with all sub-strategies) ──────
DERIBIT_API_KEY=
DERIBIT_API_SECRET=

# ── Bot mode ─────────────────────────────────────────────────────────────
# "paper" for paper trading, "live" for real trading
BOT_MODE=paper

# ── Config path override ────────────────────────────────────────────────
# CONFIG_PATH=config.yaml
