# ==============================================================================
# STRAT-004 Mean Reversion — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Binance API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Bot mode: "paper" or "live"
BOT_MODE=paper

# Config file path (default: config.yaml)
CONFIG_PATH=config.yaml

# Shared state directory for cross-strategy communication
SHARED_STATE_DIR=data/shared

# Telegram alerting (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord alerting (optional)
DISCORD_WEBHOOK_URL=

# Dashboard port override
DASHBOARD_PORT=8084
