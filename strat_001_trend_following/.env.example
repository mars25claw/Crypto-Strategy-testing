# =============================================================================
# STRAT-001 Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# Binance API credentials (REQUIRED for live trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading mode: "paper" or "live"
BOT_MODE=paper

# Optional: Deribit (not used by STRAT-001)
# DERIBIT_API_KEY=
# DERIBIT_API_SECRET=

# Alerting channels (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Email alerting (optional)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=
